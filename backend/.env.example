# PostgreSQL — Neon or Supabase connection string
DATABASE_URL=postgresql+asyncpg://kartik:157846@localhost/iot_el

# Firebase Admin SDK — download from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or inline as JSON string (for Railway/Render env vars):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Clerk — for JWT verification
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
